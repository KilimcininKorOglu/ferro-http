{
  "server": {
    "bind": "0.0.0.0",
    "port": 8080,
    "worker_threads": 1,
    "max_connections": 64,
    "keep_alive_secs": 10,
    "read_timeout_secs": 15,
    "request_max_bytes": 65536
  },
  "static": {
    "root": "/www",
    "index_files": ["index.html"]
  },
  "compression": { "gzip": true, "min_bytes": 1024 },
  "security": {
    "enable_security_headers": true,
    "rate_limit": { "enabled": true, "requests": 120, "window_secs": 60, "ban_secs": 120 }
  },
  "logging": { "level": "warn", "access_log": false }
}
